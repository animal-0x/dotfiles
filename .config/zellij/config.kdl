// Core settings
theme "custom"
default_mode "normal"
mouse_mode true
pane_frames false

// Basic keybinds for testing
keybinds clear-defaults=true {
    normal {
        bind "Ctrl g" { SwitchToMode "locked"; }
    }
    locked {
        bind "Ctrl g" { SwitchToMode "normal"; }
    }
}

// Basic theme
themes {
    custom {
        fg "#a3aed2"
        bg "#1d2230"
        black "#212736"
        red "#ff757f"
        green "#769ff0"
        yellow "#a3aed2"
        blue "#394260"
        magenta "#9d7cd8"
        cyan "#7dcfff"
        white "#c0caf5"
        orange "#ff9e64"
    }
}

// Just the essentials
plugins {
    tab-bar { path "tab-bar"; }
    status-bar { path "status-bar"; }
    compact-bar { path "compact-bar"; }
}
